t="1"><mxGeometry x="650" y="215" width="130" height="50" as="geometry"/></mxCell><mxCell id="ddb" value="DynamoDB RAG&#xa;CostOptimizationTips&#xa;32 tips by service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0D47A1;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="650" y="365" width="140" height="55" as="geometry"/></mxCell><mxCell id="otp_ddb" value="DynamoDB&#xa;ViewMyBill-OTP&#xa;TTL 5min expiry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0D47A1;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="650" y="450" width="130" height="55" as="geometry"/></mxCell><mxCell id="bedrock" value="Amazon Bedrock&#xa;Nova Lite v1&#xa;AI Analysis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="850" y="365" width="130" height="55" as="geometry"/></mxCell><mxCell id="ses" value="Amazon SES&#xa;noreply@eshkolai.com&#xa;DKIM verified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="850" y="450" width="140" height="55" as="geometry"/></mxCell><mxCell id="v1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#7B1FA2;" edge="1" parent="1" source="vmb_fe" target="apigw"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="apigw" target="ul"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#1B5E20;" edge="1" parent="1" source="apigw" target="al"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v3b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="apigw" target="otp_lambda"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#F57F17;" edge="1" parent="1" source="ul" target="s3store"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v4b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#0D47A1;dashed=1;" edge="1" parent="1" source="ul" target="leads_ddb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#F57F17;" edge="1" parent="1" source="al" target="s3store"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#0D47A1;" edge="1" parent="1" source="al" target="ddb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#C2185B;" edge="1" parent="1" source="al" target="bedrock"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#0D47A1;" edge="1" parent="1" source="otp_lambda" target="otp_ddb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="v9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#C2185B;" edge="1" parent="1" source="otp_lambda" target="ses"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram name="Bill Analysis Sequence" id="seq"><mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="t0" value="Slash My Bill — Bill Analysis Sequence Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#1B5E20;" vertex="1" parent="1"><mxGeometry x="300" y="10" width="500" height="30" as="geometry"/></mxCell><mxCell id="a1" value="User Browser" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="80" y="60" width="100" height="1100" as="geometry"/></mxCell><mxCell id="a2" value="CloudFront" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#EDE7F6;strokeColor=#4527A0;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="250" y="60" width="100" height="1100" as="geometry"/></mxCell><mxCell id="a3" value="API Gateway" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="420" y="60" width="100" height="1100" as="geometry"/></mxCell><mxCell id="a4" value="Upload&#xa;Lambda" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="590" y="60" width="100" height="1100" as="geometry"/></mxCell><mxCell id="a5" value="Bill Analyzer&#xa;Lambda" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#C8E6C9;strokeColor=#1B5E20;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="760" y="60" width="110" height="1100" as="geometry"/></mxCell><mxCell id="a6" value="S3 Storage" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="940" y="60" width="100" height="1100" as="geometry"/></mxCell><mxCell id="a7" value="DynamoDB" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#E3F2FD;strokeColor=#0D47A1;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="1110" y="60" width="100" height="1100" as="geometry"/></mxCell><mxCell id="a8" value="Bedrock&#xa;Nova Lite" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#FCE4EC;strokeColor=#C2185B;fontSize=11;fontStyle=1;size=40;" vertex="1" parent="1"><mxGeometry x="1280" y="60" width="100" height="1100" as="geometry"/></mxCell><mxCell id="p1" value="PHASE 1: OTP Verification" style="text;html=1;strokeColor=none;fillColor=#E8F5E9;align=left;fontSize=11;fontStyle=1;fontColor=#1B5E20;rounded=1;" vertex="1" parent="1"><mxGeometry x="30" y="120" width="200" height="20" as="geometry"/></mxCell><mxCell id="m1" value="1. Enter email → POST /send-otp" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#1565C0;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="155" as="sourcePoint"/><mxPoint x="470" y="155" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m2" value="2. Generate OTP → store in DynamoDB (TTL 5min)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#2E7D32;fontSize=9;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="175" as="sourcePoint"/><mxPoint x="1160" y="175" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m3" value="3. Send OTP email via SES" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#C2185B;fontSize=9;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="195" as="sourcePoint"/><mxPoint x="1330" y="195" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m4" value="4. Enter OTP → POST /verify-otp → verified ✓" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#1565C0;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="225" as="sourcePoint"/><mxPoint x="470" y="225" as="targetPoint"/></mxGeometry></mxCell><mxCell id="p2" value="PHASE 2: Upload Bill" style="text;html=1;strokeColor=none;fillColor=#FFF3E0;align=left;fontSize=11;fontStyle=1;fontColor=#E65100;rounded=1;" vertex="1" parent="1"><mxGeometry x="30" y="260" width="200" height="20" as="geometry"/></mxCell><mxCell id="m5" value="5. Select PDF → POST /upload (base64 body)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#E65100;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="295" as="sourcePoint"/><mxPoint x="470" y="295" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m6" value="6. Validate PDF (size ≤10MB, .pdf)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#2E7D32;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="470" y="315" as="sourcePoint"/><mxPoint x="640" y="315" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m7" value="7. Store bill → S3 bills/{sessionId}/" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#F57F17;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="340" as="sourcePoint"/><mxPoint x="990" y="340" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m8" value="8. Save lead → DynamoDB Leads table" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#0D47A1;fontSize=9;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="640" y="365" as="sourcePoint"/><mxPoint x="1160" y="365" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m9" value="9. Return {sessionId}" style="html=1;verticalAlign=bottom;endArrow=open;rounded=0;strokeWidth=2;strokeColor=#2E7D32;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="470" y="390" as="sourcePoint"/><mxPoint x="130" y="390" as="targetPoint"/></mxGeometry></mxCell><mxCell id="p3" value="PHASE 3: Analyze (Async Self-Invoke)" style="text;html=1;strokeColor=none;fillColor=#FCE4EC;align=left;fontSize=11;fontStyle=1;fontColor=#C2185B;rounded=1;" vertex="1" parent="1"><mxGeometry x="30" y="420" width="280" height="20" as="geometry"/></mxCell><mxCell id="m10" value="10. POST /analyze {sessionId, email}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#C2185B;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="455" as="sourcePoint"/><mxPoint x="470" y="455" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m11" value="11. Set S3 processing marker" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#F57F17;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="480" as="sourcePoint"/><mxPoint x="990" y="480" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m12" value="12. lambda.invoke(self, Event) → async" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#1B5E20;fontSize=10;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="505" as="sourcePoint"/><mxPoint x="860" y="505" as="targetPoint"/><Array as="points"><mxPoint x="850" y="505"/><mxPoint x="850" y="520"/><mxPoint x="815" y="520"/></Array></mxGeometry></mxCell><mxCell id="m13" value="13. Return 202 {status: processing}" style="html=1;verticalAlign=bottom;endArrow=open;rounded=0;strokeWidth=2;strokeColor=#7B1FA2;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="470" y="540" as="sourcePoint"/><mxPoint x="130" y="540" as="targetPoint"/></mxGeometry></mxCell><mxCell id="p3b" value="ASYNC LAMBDA (separate invocation, up to 15 min)" style="text;html=1;strokeColor=#1B5E20;fillColor=#C8E6C9;align=center;fontSize=10;fontStyle=1;fontColor=#1B5E20;rounded=1;" vertex="1" parent="1"><mxGeometry x="700" y="560" width="320" height="20" as="geometry"/></mxCell><mxCell id="m14" value="14. Get bill PDF from S3" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#F57F17;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="595" as="sourcePoint"/><mxPoint x="990" y="595" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m15" value="15. Parse bill (pdfplumber → line items, services)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#1B5E20;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="620" as="sourcePoint"/><mxPoint x="860" y="620" as="targetPoint"/><Array as="points"><mxPoint x="850" y="620"/><mxPoint x="850" y="635"/><mxPoint x="815" y="635"/></Array></mxGeometry></mxCell><mxCell id="m16" value="16. Fetch optimization tips (RAG)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#0D47A1;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="660" as="sourcePoint"/><mxPoint x="1160" y="660" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m17" value="17. Invoke Bedrock Nova Lite (AI analysis)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#C2185B;fontSize=10;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="690" as="sourcePoint"/><mxPoint x="1330" y="690" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m18" value="18. Return JSON analysis (summary, recommendations)" style="html=1;verticalAlign=bottom;endArrow=open;rounded=0;strokeWidth=2;strokeColor=#C2185B;fontSize=9;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1330" y="720" as="sourcePoint"/><mxPoint x="815" y="720" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m19" value="19. Generate PDF report (ReportLab + PyPDF2)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#1B5E20;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="750" as="sourcePoint"/><mxPoint x="860" y="750" as="targetPoint"/><Array as="points"><mxPoint x="850" y="750"/><mxPoint x="850" y="765"/><mxPoint x="815" y="765"/></Array></mxGeometry></mxCell><mxCell id="m20" value="20. Upload report PDF → S3 reports/{sessionId}/" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#F57F17;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="790" as="sourcePoint"/><mxPoint x="990" y="790" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m21" value="21. Save result.json (downloadUrl, summary)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#F57F17;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="820" as="sourcePoint"/><mxPoint x="990" y="820" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m22" value="22. Clear processing marker" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#F57F17;fontSize=9;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="845" as="sourcePoint"/><mxPoint x="990" y="845" as="targetPoint"/></mxGeometry></mxCell><mxCell id="p4" value="PHASE 4: Polling" style="text;html=1;strokeColor=none;fillColor=#E8EAF6;align=left;fontSize=11;fontStyle=1;fontColor=#283593;rounded=1;" vertex="1" parent="1"><mxGeometry x="30" y="880" width="200" height="20" as="geometry"/></mxCell><mxCell id="m23" value="23. Poll POST /analyze (every 5s)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#283593;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="915" as="sourcePoint"/><mxPoint x="470" y="915" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m24" value="24. Check S3 for result.json" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=1;strokeColor=#F57F17;fontSize=9;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="815" y="940" as="sourcePoint"/><mxPoint x="990" y="940" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m25" value="25. Return 202 (still processing) or 200 (complete)" style="html=1;verticalAlign=bottom;endArrow=open;rounded=0;strokeWidth=2;strokeColor=#283593;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="470" y="965" as="sourcePoint"/><mxPoint x="130" y="965" as="targetPoint"/></mxGeometry></mxCell><mxCell id="p5" value="PHASE 5: Result" style="text;html=1;strokeColor=none;fillColor=#E8F5E9;align=left;fontSize=11;fontStyle=1;fontColor=#1B5E20;rounded=1;" vertex="1" parent="1"><mxGeometry x="30" y="1000" width="200" height="20" as="geometry"/></mxCell><mxCell id="m26" value="26. Poll returns {status: complete, downloadUrl, summary}" style="html=1;verticalAlign=bottom;endArrow=open;rounded=0;strokeWidth=2;strokeColor=#1B5E20;fontSize=10;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="470" y="1035" as="sourcePoint"/><mxPoint x="130" y="1035" as="targetPoint"/></mxGeometry></mxCell><mxCell id="m27" value="27. Open report PDF in new tab (presigned S3 URL, 24h expiry)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeWidth=2;strokeColor=#1B5E20;fontSize=10;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="1065" as="sourcePoint"/><mxPoint x="990" y="1065" as="targetPoint"/></mxGeometry></mxCell><mxCell id="note1" value="Files auto-deleted after 24h&#xa;(S3 lifecycle rules)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=9;align=center;" vertex="1" parent="1"><mxGeometry x="1050" y="790" width="150" height="45" as="geometry"/></mxCell><mxCell id="note2" value="Async invocation runs&#xa;independently up to 15 min&#xa;(900s Lambda timeout)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#C8E6C9;strokeColor=#1B5E20;fontSize=9;align=center;" vertex="1" parent="1"><mxGeometry x="1050" y="600" width="170" height="50" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>
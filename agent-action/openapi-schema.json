{
  "openapi": "3.0.0",
  "info": {
    "title": "SlashMyBill FinOps Actions",
    "version": "2.1.0",
    "description": "Action group for SlashMyBill Bedrock Agent"
  },
  "paths": {
    "/get-cost-data": {
      "post": {
        "operationId": "getCostData",
        "summary": "Get cost breakdown by service and daily trend",
        "description": "Gets cost by service for last 30 days and daily trend. Use usageTypeBreakdown=true with serviceFilter for specific service deep-dive.",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}},
          {"name": "usageTypeBreakdown", "in": "query", "description": "Set to true to get usage type level breakdown for a specific service", "required": false, "schema": {"type": "string", "description": "Set to true to get usage type level breakdown"}},
          {"name": "serviceFilter", "in": "query", "description": "AWS service name to filter usage types e.g. Amazon Rekognition or Amazon Simple Storage Service", "required": false, "schema": {"type": "string", "description": "AWS service name to filter for usage type breakdown"}}
        ],
        "responses": {"200": {"description": "Cost data response"}}
      }
    },
    "/get-monthly-comparison": {
      "post": {
        "operationId": "getMonthlyComparison",
        "summary": "Compare costs across months",
        "description": "Gets monthly cost breakdown by service for last 3 to 6 months",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}},
          {"name": "months", "in": "query", "description": "Number of months default 3 max 6", "required": false, "schema": {"type": "string", "description": "Number of months default 3 max 6"}}
        ],
        "responses": {"200": {"description": "Monthly comparison response"}}
      }
    },
    "/get-ec2-instances": {
      "post": {
        "operationId": "getEC2Instances",
        "summary": "List EC2 instances with CPU metrics",
        "description": "Lists EC2 instances with type state and 14 day average CPU",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "EC2 instances response"}}
      }
    },
    "/get-rds-instances": {
      "post": {
        "operationId": "getRDSInstances",
        "summary": "List RDS instances with metrics",
        "description": "Lists RDS instances with class engine storage and CPU",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "RDS instances response"}}
      }
    },
    "/get-lambda-functions": {
      "post": {
        "operationId": "getLambdaFunctions",
        "summary": "List Lambda functions with metrics",
        "description": "Lists Lambda functions with runtime memory invocations errors",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "Lambda functions response"}}
      }
    },
    "/get-s3-buckets": {
      "post": {
        "operationId": "getS3Buckets",
        "summary": "List S3 buckets",
        "description": "Lists S3 buckets with lifecycle policy status",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "S3 buckets response"}}
      }
    },
    "/get-ebs-volumes": {
      "post": {
        "operationId": "getEBSVolumes",
        "summary": "List EBS volumes",
        "description": "Lists EBS volumes with type size attachment status",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "EBS volumes response"}}
      }
    },
    "/get-network-resources": {
      "post": {
        "operationId": "getNetworkResources",
        "summary": "List NAT Gateways and Elastic IPs",
        "description": "Lists NAT Gateways VPC Endpoints and Elastic IPs",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "Network resources response"}}
      }
    },
    "/get-budgets": {
      "post": {
        "operationId": "getBudgets",
        "summary": "List AWS Budgets",
        "description": "Lists AWS Budgets with spend and forecast",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "Budgets response"}}
      }
    },
    "/get-finops-settings": {
      "post": {
        "operationId": "getFinOpsSettings",
        "summary": "Get FinOps settings healthcheck",
        "description": "Returns FinOps settings scan results for the account",
        "parameters": [
          {"name": "accountId", "in": "query", "description": "The 12-digit AWS account ID", "required": true, "schema": {"type": "string", "description": "The 12-digit AWS account ID"}},
          {"name": "memberEmail", "in": "query", "description": "Member email for role assumption", "required": true, "schema": {"type": "string", "description": "Member email for role assumption"}}
        ],
        "responses": {"200": {"description": "FinOps settings response"}}
      }
    },
    "/get-aws-pricing": {
      "post": {
        "operationId": "getAWSPricing",
        "summary": "Get real-time AWS pricing",
        "description": "Queries AWS Pricing API for current pricing data",
        "parameters": [
          {"name": "serviceCode", "in": "query", "description": "AWS service code like AmazonEC2 AmazonRDS AmazonS3", "required": true, "schema": {"type": "string", "description": "AWS service code like AmazonEC2 AmazonRDS AmazonS3"}},
          {"name": "filters", "in": "query", "description": "Key value filters like instanceType m5.large", "required": false, "schema": {"type": "string", "description": "Key value filters like instanceType m5.large"}},
          {"name": "region", "in": "query", "description": "AWS region code default us-east-1", "required": false, "schema": {"type": "string", "description": "AWS region code default us-east-1"}}
        ],
        "responses": {"200": {"description": "Pricing response"}}
      }
    },
    "/update-drilldown-plan": {
      "post": {
        "operationId": "updateDrilldownPlan",
        "summary": "Update or create a drilldown plan for a tip",
        "description": "Writes corrected drilldownApis to the Tips table. Used by self-healing when a drilldown plan has invalid service or operation names.",
        "parameters": [
          {"name": "service", "in": "query", "description": "The service partition key in the Tips table (e.g. EC2, S3, LAMBDA)", "required": true, "schema": {"type": "string"}},
          {"name": "tipId", "in": "query", "description": "The tipId sort key in the Tips table", "required": true, "schema": {"type": "string"}},
          {"name": "drilldownApis", "in": "query", "description": "JSON string of the drilldownApis array. Each entry is {service, operation, params}.", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "Update result"}}
      }
    }
  }
}
